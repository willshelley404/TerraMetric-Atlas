# ─────────────────────────────────────────────────────────────────────────────
# .Renviron.example  →  Copy to .Renviron and fill in your keys
# ─────────────────────────────────────────────────────────────────────────────

# ── Data APIs ─────────────────────────────────────────────────────────────────
# FRED (Free) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# BLS (Free) — https://www.bls.gov/developers/home.htm
BLS_API_KEY=your_bls_api_key_here

# U.S. Census (Free) — https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# NewsAPI (Free tier: 100 req/day) — https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# ── LLM Providers (only one required) ────────────────────────────────────────
# Groq — https://console.groq.com  (fastest free tier)
# Models: llama-3.3-70b-versatile (knowledge ~Dec 2024), llama-3.1-8b-instant
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter — https://openrouter.ai  (access to many free models)
# Free models: deepseek/deepseek-r1:free (~Jan 2025), deepseek/deepseek-chat:free
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Gemini — https://aistudio.google.com/apikey  (free tier via AI Studio)
# Models: gemini-2.0-flash (~early 2025 knowledge, fast)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Provider override (optional — auto-detected if not set) ──────────────────
# Values: "groq", "openrouter", "gemini"
LLM_PROVIDER=groq

# ── News cache ────────────────────────────────────────────────────────────────
# Leave blank → uses ./cache/ (auto-created, works locally)
# Shiny Server: ECONPULSE_CACHE_DIR=/var/shiny-server/econpulse/cache
# Posit Connect: ECONPULSE_CACHE_DIR=/home/rstudio/econpulse_cache
ECONPULSE_CACHE_DIR=
