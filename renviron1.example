# ─────────────────────────────────────────────────────────────────────────────
# .Renviron.example  →  Copy to .Renviron and fill in your keys
# ─────────────────────────────────────────────────────────────────────────────
#
# FRED API (Free) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# BLS API (Free) — https://www.bls.gov/developers/home.htm
BLS_API_KEY=your_bls_api_key_here

# U.S. Census API (Free) — https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# ── LLM Provider (choose one or more) ────────────────────────────────────────
# Groq (Free tier, fastest) — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (Free models available) — https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Together AI (Free credits) — https://api.together.xyz
TOGETHER_API_KEY=your_together_api_key_here

# ── News Provider ─────────────────────────────────────────────────────────────
# NewsAPI (Free tier: 100 req/day) — https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here

# ── Active LLM Provider Override (optional) ───────────────────────────────────
# Set to: "groq", "openrouter", or "together"
# If not set, auto-detected from whichever key is present
LLM_PROVIDER=groq
